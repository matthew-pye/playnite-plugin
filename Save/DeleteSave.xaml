<PluginUserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008" x:Class="RomM.Save.RomMDeleteSaveView"
            xmlns:local="clr-namespace:RomM.Save"
            DataContext="{Binding RelativeSource={RelativeSource Self}}"
            Background="Transparent"
            xmlns:sys="clr-namespace:System;assembly=mscorlib" mc:Ignorable="d" d:DesignHeight="50" d:DesignWidth="500" Padding="2,0,2,4">

        <DockPanel>
        <StackPanel x:Name="SelectorPanel">
            <Separator Margin="0,5,0,0" />
            <Grid Margin="5,5,5,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="4*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="35"/>
                </Grid.RowDefinitions>
                <Button Name="Cancel_btn" Click="Click_Cancel" Grid.Row="0" Grid.Column="0" Margin="5,0,0,0" Background="#808080">
                    <Label Content="Cancel" Grid.Row="0" Grid.Column="0"/>
                </Button>
                <Button Name="LocalOnly_btn" Click="Click_LocalOnly" Grid.Row="0" Grid.Column="1" Margin="5,0,0,0" Background="Red">
                    <Label Content="Delete Locally" Grid.Row="0" Grid.Column="0"/>
                </Button>
                <Button Name="RemoteOnly_btn" Click="Click_RemoteOnly" Grid.Row="0" Grid.Column="2" Margin="5,0,0,0" Background="Orange">
                    <Label Content="Delete from Server" Grid.Row="0" Grid.Column="0"/>
                </Button>
                <Button Name="Delete_btn" Click="Click_Delete" Grid.Row="0" Grid.Column="3" Margin="5,0,0,0" Background="#45a240">
                    <Label Content="Delete Both" Grid.Row="0" Grid.Column="0"/>
                </Button>

            </Grid>
        </StackPanel>
    </DockPanel>
</PluginUserControl>
