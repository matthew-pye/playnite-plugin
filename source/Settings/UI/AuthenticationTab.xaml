<UserControl x:Class="Graviton.Settings.AuthenticationTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:s="clr-namespace:Graviton.Settings"
             xmlns:loc="clr-namespace:Playnite"
             mc:Ignorable="d"
             d:DesignHeight="540" d:DesignWidth="960">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Graviton;component/ThemingDefaults.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <s:InvertBoolConverter x:Key="InvertBoolConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel>
        <Border Grid.Column="0" BorderThickness="1" CornerRadius="3" BorderBrush="{DynamicResource Graviton.Background.Colour}">
            <Grid Margin="5,10,5,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="5*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- #region UserData -->
                <Grid Grid.Column="0" Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- #region Status -->
                    <Border Grid.Row="0" Grid.Column="0" CornerRadius="6" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5,10,5,5">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource Graviton.WarnBackground.Colour}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="OK">
                                        <Setter Property="Background" Value="{DynamicResource Graviton.SuccessBackground.Colour}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="Unauthorized">
                                        <Setter Property="Background" Value="{DynamicResource Graviton.ErrorBackground.Colour}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="Forbidden">
                                        <Setter Property="Background" Value="{DynamicResource Graviton.ErrorBackground.Colour}"/>
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding AccountState.AuthenticateFailed}" Value="{x:Null}" />
                                            <Condition Binding="{Binding AccountState.UserID}" Value="-1" />
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.Setters>
                                            <Setter Property="Background" Value="{DynamicResource Graviton.SubSubText.Colour}"/>
                                        </MultiDataTrigger.Setters>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Margin="5">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource Graviton.Warn.Colour}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="OK">
                                                <Setter Property="Fill" Value="{DynamicResource Graviton.Success.Colour}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="Unauthorized">
                                                <Setter Property="Fill" Value="{DynamicResource Graviton.Error.Colour}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="Forbidden">
                                                <Setter Property="Fill" Value="{DynamicResource Graviton.Error.Colour}"/>
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding AccountState.AuthenticateFailed}" Value="{x:Null}" />
                                                    <Condition Binding="{Binding AccountState.UserID}" Value="-1" />
                                                </MultiDataTrigger.Conditions>
                                                <MultiDataTrigger.Setters>
                                                    <Setter Property="Fill" Value="{DynamicResource Graviton.Text.Colour}"/>
                                                </MultiDataTrigger.Setters>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock FontSize="12" Margin="0,2,5,2">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Reconnecting..."/>
                                        <Setter Property="Foreground" Value="{DynamicResource Graviton.Warn.Colour}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="OK">
                                                <Setter Property="Text" Value="Logged In"/>
                                                <Setter Property="Foreground" Value="{DynamicResource Graviton.Success.Colour}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="Unauthorized">
                                                <Setter Property="Text" Value="Logged Out"/>
                                                <Setter Property="Foreground" Value="{DynamicResource Graviton.Error.Colour}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="Forbidden">
                                                <Setter Property="Text" Value="Logged Out"/>
                                                <Setter Property="Foreground" Value="{DynamicResource Graviton.Error.Colour}"/>
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding AccountState.AuthenticateFailed}" Value="{x:Null}" />
                                                    <Condition Binding="{Binding AccountState.UserID}" Value="-1" />
                                                </MultiDataTrigger.Conditions>
                                                <MultiDataTrigger.Setters>
                                                    <Setter Property="Text" Value="Not Logged In"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource Graviton.Text.Colour}"/>
                                                </MultiDataTrigger.Setters>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <!-- #endregion -->

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,10,5,0">
                        <Label Name="RomMServerVersionText" Content="Server Ver." Foreground="{DynamicResource Graviton.SubSubText.Colour}" FontSize="12"/>
                        <Label Name="RomMServerVersion" Content="{Binding AccountState.ServerVersion, Mode=OneWay}" Foreground="{DynamicResource Graviton.SubSubText.Colour}" FontSize="12" Margin="0"/>
                    </StackPanel>

                    <!-- #region Profile Icon -->
                    <Grid Grid.Column="0" Grid.Row="2" Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid Name="ProfileIconGrid" Grid.Column="0" Margin="0,10,0,0">
                            <Border Name="ProfileIconBorder" BorderThickness="0" CornerRadius="8" ClipToBounds="True">
                                <Border.Background>
                                    <ImageBrush ImageSource="{Binding ProfilePath, Mode=OneWay, Converter={StaticResource imageCacheConverter}}" Stretch="UniformToFill" AlignmentX="Center" AlignmentY="Center"/>
                                </Border.Background>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, ElementName=ProfileIconGrid}" Value="True">
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsMouseOver, ElementName=ProfileEditButton}" Value="True">
                                                <Setter Property="Opacity" Value="0.5"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Grid>
                        <Button Grid.Column="0" Name="ProfileEditButton" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="10" Click="Click_UpdateProfileIcon">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Opacity" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=ProfileIconGrid}" Value="True">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="&#xf03eb;" FontFamily="{StaticResource NerdFont}" FontSize="24"/>
                        </Button>
                    </Grid>
                    <!-- #endregion -->

                    <TextBlock Name="RomMLoggedStatus" Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="2" FontSize="18" FontWeight="Bold" VerticalAlignment="Bottom" Margin="5">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="OK">
                                        <Setter Property="Text" Value="Logged In"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="Unauthorized">
                                        <Setter Property="Text" Value="Logged Out"/>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="Forbidden">
                                        <Setter Property="Text" Value="Logged Out"/>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding AccountState.AuthenticateFailed}" Value="{x:Null}" />
                                            <Condition Binding="{Binding AccountState.UserID}" Value="-1" />
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.Setters>
                                            <Setter Property="Text" Value="Not Logged In"/>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger.Setters>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Name="RomMUser" Text="{Binding AccountState.User, Mode=OneWay}" Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="2" FontSize="22" FontWeight="Bold" Margin="10,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="Unauthorized">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="Forbidden">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding AccountState.AuthenticateFailed}" Value="{x:Null}" />
                                            <Condition Binding="{Binding AccountState.UserID}" Value="-1" />
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.Setters>
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </MultiDataTrigger.Setters>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Name="RomMProfileType" Text="{Binding AccountState.UserType, Mode=OneWay}" Grid.Column="0" Grid.Row="4" Grid.ColumnSpan="2" Margin="20,0,0,0" Foreground="DimGray" FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="Unauthorized">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="Forbidden">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding AccountState.AuthenticateFailed}" Value="{x:Null}" />
                                            <Condition Binding="{Binding AccountState.UserID}" Value="-1" />
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.Setters>
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </MultiDataTrigger.Setters>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </Grid>
                <!-- #endregion -->

                <Border Grid.Column="0" Grid.RowSpan="2" BorderThickness="1" CornerRadius="3" BorderBrush="#41696969" Width="1" HorizontalAlignment="Right" Margin="0,0,-1,0"/>

                <!-- #region Login -->
                <Grid Grid.Column="1" Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="5*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="3" Margin="10,5,10,10">
                        <TextBox x:Name="ServerAddressBox" Text="{Binding Host, Mode=TwoWay}" VerticalAlignment="Center"/>
                        <TextBlock Text="Server Address" IsHitTestVisible="False" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0,0,0" Foreground="{DynamicResource Graviton.SubSubText.Colour}">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Foreground" Value="{DynamicResource Graviton.SubSubText.Colour}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=ServerAddressBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- #region QR Code -->
                    <Border BorderThickness="1" CornerRadius="8" ClipToBounds="True" BorderBrush="#41373737" Background="#41373737" Margin="10" Grid.Row="1" Grid.Column="0" Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}}">
                        <TextBlock Name="TempQRText" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{StaticResource NerdFont}" FontSize="56" Text="&#xf029;"/>
                    </Border>
                    <Border Name="LoginQRBorder" Visibility="Hidden" BorderThickness="1" CornerRadius="8" ClipToBounds="True" BorderBrush="#41373737" Margin="10" Grid.Row="1" Grid.Column="0" Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}}"/>
                    <TextBlock Name="LoginQRTimer" Grid.Row="2" Grid.Column="0" HorizontalAlignment="Center" Visibility="Collapsed"/>
                    <!-- #endregion -->

                    <!-- #region User Interact -->
                    <Grid Grid.Row="1" Grid.Column="1" Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Margin="0,15,0,0"  Text="Login with QR code" Grid.Row="0" HorizontalAlignment="Left" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="Scan with phone or open in browser." Grid.Row="1" HorizontalAlignment="Left" FontSize="16" Foreground="Gray"/>
                        <StackPanel Orientation="Horizontal" Grid.Row="2">
                            <Button Name="QRAuth" Click="Click_LoginViaQR" Margin="5" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Name="QRAuthText" Text="Start" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                            <Button Name="OpenInBrowser" Click="Click_OnInBrowser" Visibility="Collapsed" Margin="5" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Name="OpenInBrowserText" Text="Open in browser" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>

                        <TextBlock Margin="5" Grid.Row="3" Text="or" HorizontalAlignment="Left" FontSize="16" Foreground="Gray"/>
                        <Grid Margin="5" Grid.Row="4" VerticalAlignment="Bottom">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <TextBox x:Name="ClientTokenBox" Text="{Binding ClientTokenNP, Mode=TwoWay}"/>
                                <TextBlock Name="ClientTokenPlaceholder" Text="Login with Client Token" IsHitTestVisible="False" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0,0,0" Foreground="{DynamicResource Graviton.SubSubText.Colour}">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=ClientTokenBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <Button Grid.Column="1" Name="ConnectButton" Click="Click_Authenticate" Margin="5,0,5,0">
                                <TextBlock Name="AuthButtonText" Text="Connect" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                        </Grid>
                    </Grid>
                    <!-- #endregion -->

                </Grid>

                <!-- #region Advance Login-->
                <Border Margin="5" Grid.Column="1" Grid.Row="1" BorderThickness="1" CornerRadius="3" BorderBrush="#41696969" VerticalAlignment="Top" HorizontalAlignment="Stretch"/>
                <Expander Margin="10,15,0,0" Grid.Column="1" Grid.Row="1"  Header="Advanced: sign in with username and password">
                    <Expander.Style>
                        <Style TargetType="Expander">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Expander">
                                        <StackPanel>
                                            <ToggleButton x:Name="HeaderToggle" Foreground="DimGray" IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}" Content="{TemplateBinding Header}" Focusable="False">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <StackPanel Orientation="Horizontal" Background="Transparent" Cursor="Hand">
                                                            <Path x:Name="Arrow"
                                                                        Data="M 0,4 L 5,0 L 10,4"
                                                                        Stroke="Gray" StrokeThickness="2"
                                                                        StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                                        Width="10" Height="6" Stretch="Uniform"
                                                                        VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                        Margin="4,0,10,0"
                                                                        RenderTransformOrigin="0.5,0.5">
                                                                <Path.RenderTransform>
                                                                    <RotateTransform x:Name="ArrowRotate" Angle="0"/>
                                                                </Path.RenderTransform>
                                                            </Path>
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Trigger.EnterActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation Storyboard.TargetName="ArrowRotate" Storyboard.TargetProperty="Angle" To="180" Duration="0:0:0.15"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </Trigger.EnterActions>
                                                                <Trigger.ExitActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation Storyboard.TargetName="ArrowRotate" Storyboard.TargetProperty="Angle" To="0" Duration="0:0:0.15"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </Trigger.ExitActions>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>
                                            <ContentPresenter x:Name="ExpandSite" Visibility="Collapsed"/>
                                        </StackPanel>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsExpanded" Value="True">
                                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Expander.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Name="UserPassWarning" Margin="10,5,5,5" Text="Warning! Using this is NOT recommended!" TextWrapping="Wrap" Grid.Row="0" Foreground="#ffb329"/>

                        <CheckBox IsChecked="{Binding UseBasicAuth, Mode=TwoWay}" Grid.Row="1" Margin="5">
                            <TextBlock Name="UseBasicAuthText" Text="Use Basic Auth" TextWrapping="Wrap" FontSize="12"/>
                        </CheckBox>

                        <Grid Grid.Row="2" Margin="5">
                            <TextBox x:Name="UsernameBox" Text="{Binding UsernameNP, Mode=TwoWay}"/>
                            <TextBlock Text="Username" IsHitTestVisible="False" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0,0,0" Foreground="{DynamicResource Graviton.SubSubText.Colour}">
                                <TextBlock.Style>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UsernameNP}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <Grid Grid.Row="3" Margin="5">
                            <TextBox x:Name="RomMPasswordUnmasked" Text="{Binding PasswordNP, Mode=TwoWay}" Visibility="Collapsed" FontSize="14" Margin="5,0,0,0"/>
                            <PasswordBox x:Name="RomMPassword" FontSize="14" PasswordChar="●" PasswordChanged="RomMPassword_PasswordChanged"/>
                            <TextBlock Text="Password" FontSize="14" IsHitTestVisible="False" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0,0,0" Foreground="{DynamicResource Graviton.SubSubText.Colour}">
                                <TextBlock.Style>
                                    <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PasswordNP}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Button Name="ShowPassword" Content="&#xea70;" FontSize="18" HorizontalAlignment="Right" Margin="0,0,10,0" Click="Click_ShowPassword">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="DimGray"/>
                                        <Setter Property="Opacity" Value="0.7"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <Button Name="BasicLoginButton" Grid.Column="1" Grid.Row="3" Click="Click_BasicLogin" Margin="5">
                            <TextBlock Name="BasicLoginText" Text="Login" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                    </Grid>
                </Expander>
                <!-- #endregion-->
                
                <!-- #endregion -->
                
            </Grid>
        </Border>

        <!-- #region Advance Options -->
        <TextBlock Name="AdvanceOptionsText" Text="Advanced Options" Grid.Row="8" Grid.ColumnSpan="2" Margin="5" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="18" FontWeight="Bold"/>
        <Separator Grid.Row="8" Grid.ColumnSpan="4" VerticalAlignment="Bottom" Margin="5"/>

        <TextBlock Name="CustomHeadersText" Text="Custom Headers" FontSize="16" FontWeight="SemiBold" Grid.Row="9" Grid.ColumnSpan="2" Margin="5" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="10" Grid.ColumnSpan="2">
            <ItemsControl ItemsSource="{Binding CustomHeaders, Mode=TwoWay}" Grid.Row="9" Grid.ColumnSpan="2">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding Enabled}" Checked="Header_Checked" Unchecked="Header_Unchecked" />
                            <Grid>
                                <TextBox MinWidth="250" VerticalAlignment="Center" HorizontalAlignment="Left" x:Name="HeaderNameText" Margin="5" Text="{Binding Name, Mode=TwoWay}" IsEnabled="{Binding Enabled, Converter={StaticResource InvertBoolConverter}}"/>
                                <TextBlock Text="{loc:LocalizedString Game}" IsHitTestVisible="False" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="DarkGray">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=HeaderNameText}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <Grid>
                                <TextBox MinWidth="250" VerticalAlignment="Center" HorizontalAlignment="Left" x:Name="HeaderValueText" Margin="5" Text="{Binding Value, Mode=TwoWay}" IsEnabled="{Binding Enabled, Converter={StaticResource InvertBoolConverter}}"/>
                                <TextBlock x:Name="HeaderValuePlaceholderText" IsHitTestVisible="False" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="DarkGray">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=HeaderValueText}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <Button Click="Click_RemoveHeader" FontSize="16" Margin="5" HorizontalAlignment="Left">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#6a3a3a"/>
                                        <Setter Property="Opacity" Value="0.6"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    </ContentPresenter>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="1"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Name="DeleteHeaderText"  Text="&#xf05e8;" Margin="2,0,5,0"/>
                            </Button>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Click="Click_AddHeader" FontSize="16" Margin="5" HorizontalAlignment="Left">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Foreground" Value="Gray"/>
                        <Setter Property="Opacity" Value="0.6"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                    </ContentPresenter>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="1"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <TextBlock Name="AddHeaderText" Text="&#xea60; New Header" Margin="2,0,5,0"/>
            </Button>
        </StackPanel>
        <!-- #endregion -->

    </StackPanel>

</UserControl>