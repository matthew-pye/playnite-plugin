<UserControl x:Class="Graviton.Settings.SettingsTabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:s="clr-namespace:Graviton.Settings"
             mc:Ignorable="d"
             d:DesignHeight="1000" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        <s:ImageCacheConverter x:Key="imageCacheConverter" />
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="LightGray" />
        </Style>
        <Style TargetType="{x:Type Label}">
            <Setter Property="Foreground" Value="LightGray" />
        </Style>
        <Style TargetType="{x:Type TabItem}">
            <Setter Property="FontSize" Value="18"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <StackPanel Margin="10,2">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header"/>
                            <Rectangle Name="Rectangle" Fill="#55cdff" Height="2" Margin="-3,5,-3,-3"/>
                        </StackPanel>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#55cdff"/>
                                <Setter TargetName="Rectangle" Property="Fill" Value="#55cdff"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="LightGray"/>
                                <Setter TargetName="Rectangle" Property="Fill" Value="Transparent"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <TabControl Name="SettingsTabs">

            <!-- Authentication -->
            <TabItem Header="&#xf0004; Authentication">
                <s:AuthenticationTab FontSize="14" Margin="5,10,5,5"/>
            </TabItem>

            <!-- Options -->
            <TabItem Header="&#xf013; Options">
                <s:OptionsTab FontSize="14" Margin="5,10,5,5"/>
            </TabItem>

            <!-- Mappings -->
            <TabItem Header="&#xf0eb6; Mappings" Selector.Selected="MappingTabItem_Selected">
                <s:MappingsTab FontSize="14" Margin="5,10,5,5"/>
            </TabItem>

            <!-- Saves -->
            <TabItem Header="&#xf0193; Saves">

            </TabItem>

            <!-- Save States -->
            <TabItem Header="&#xeea8; Save States">

            </TabItem>

            <!-- Dev options -->
            <TabItem Name="DEVTAB" Header="&#xeef4; Dev Settings">
                <s:DevTab FontSize="14" Margin="5,10,5,5"/>
            </TabItem>

        </TabControl>
    </DockPanel>
</UserControl>
