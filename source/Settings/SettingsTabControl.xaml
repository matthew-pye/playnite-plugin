<UserControl x:Class="Graviton.Settings.SettingsTabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:s="clr-namespace:Graviton.Settings"
             mc:Ignorable="d"
             d:DesignHeight="1000" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Graviton;component/ThemingDefaults.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="{x:Type TabItem}">
                <Setter Property="FontSize" Value="18"/>

                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type TabItem}">
                            <StackPanel Margin="10,2">
                                <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header"/>
                                <Rectangle Name="Rectangle" Fill="#8b74e8" Height="2" Margin="-3,5,-3,-3"/>
                            </StackPanel>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="#8b74e8"/>
                                    <Setter TargetName="Rectangle" Property="Fill" Value="#8b74e8"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="False">
                                    <Setter Property="Foreground" Value="#524489"/>
                                    <Setter TargetName="Rectangle" Property="Fill" Value="Transparent"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <TabControl Name="SettingsTabs" FontSize="14" FontFamily="{StaticResource NerdFont}">

            <!-- Authentication -->
            <TabItem Name="AuthItem" Header="&#xf0004; Authentication">
                <s:AuthenticationTab Margin="5,10,5,5"/>
            </TabItem>

            <!-- Options -->
            <TabItem Name="OptionsItem" Header="&#xf013; Options">
                <s:OptionsTab Margin="5,10,5,5"/>
            </TabItem>

            <!-- Mappings -->
            <TabItem Name="MappingsItem" Header="&#xf0eb6; Emulator Mappings">
                <s:MappingsTab Margin="5,10,5,5" ManageSavesRequested="MappingsTab_ManageSavesRequested"/>
            </TabItem>

            <!-- Saves 
            <TabItem Name="SavesItem" Header="&#xf0193; Saves">

            </TabItem>-->

            <!-- Save States 
            <TabItem Name="SaveStatesItem" Header="&#xeea8; Save States">

            </TabItem>-->

            <!-- Dev options -->
            <TabItem Name="DEVTAB" Header="&#xeef4; Dev Settings">
                <s:DevTab Margin="5,10,5,5"/>
            </TabItem>

        </TabControl>

        <ContentControl Name="SettingsFullView" Visibility="Collapsed"/>
    </Grid>
</UserControl>
