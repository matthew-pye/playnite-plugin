<UserControl x:Class="Graviton.Settings.OptionsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:s="clr-namespace:Graviton.Settings"
             xmlns:models="clr-namespace:Graviton.Models.RomM.Saves"
             xmlns:psdk="clr-namespace:Playnite.Desktop;assembly=Playnite.SDK"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="750">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Graviton;component/ThemingDefaults.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <ObjectDataProvider x:Key="SaveConflictStyleValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
                <ObjectDataProvider.MethodParameters>
                    <x:Type TypeName="models:SaveConflictStyle"/>
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer>
        <StackPanel>

            <Border Margin="10" CornerRadius="8" BorderBrush="{DynamicResource Graviton.Background.Colour}" BorderThickness="1" Background="Transparent">
                <StackPanel>
                    <TextBlock Name="LibraryScanningText" Text="Library scanning" FontSize="20" FontWeight="Bold" Margin="10,10,10,15" />

                    <CheckBox IsChecked="{Binding MergeRevisions, Mode=TwoWay}" Margin="5">
                        <TextBlock Name="MergeROMText" Text="Merge ROM revisions" TextWrapping="Wrap"/>
                    </CheckBox>
                    <CheckBox IsChecked="{Binding KeepDeletedGames, Mode=TwoWay}" Margin="5">
                        <TextBlock Name="KeepDeleteText" Text="Keep games deleted from RomM server" TextWrapping="Wrap"/>
                    </CheckBox>
                    <CheckBox IsChecked="{Binding SkipMissingFiles, Mode=TwoWay}" Margin="5">
                        <TextBlock Name="SkipDeletedText" Text="Skip importing ROMs that are missing from RomM servers filesystem" TextWrapping="Wrap"/>
                    </CheckBox>

                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Name="ExcludeGenresText" Text="Exclude Genres" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5"/>
                        <Grid Grid.Column="1" Margin="5">
                            <TextBox x:Name="ExcludeGenresBox" Text="{Binding ExcludeGenres, Mode=TwoWay}"/>
                            <TextBlock x:Name="ExcludeGenresPlaceholderText" IsHitTestVisible="False" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="{DynamicResource Graviton.SubText.Colour}">
                                <TextBlock.Style>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=ExcludeGenresBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Margin="10" CornerRadius="8" BorderBrush="{DynamicResource Graviton.Background.Colour}" BorderThickness="1" Background="Transparent">
                <StackPanel>
                    <TextBlock Name="InstallationText" Text="Installation" FontSize="20" FontWeight="Bold" Margin="10,10,10,15" />

                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" IsChecked="{Binding Use7z, Mode=TwoWay}" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Name="Use7zText" Text="Use 7z for archive extraction" TextWrapping="Wrap"/>
                        </CheckBox>
                        <TextBox Margin="5,0,5,0" Grid.Column="1" x:Name="PathTo7zText" Text="{Binding PathTo7z, Mode=TwoWay}" />
                        <Button  Grid.Column="2" Click="Browse7zPath_Click">
                            <TextBlock Name="Browse7zText" Text="Browse" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Margin="10" CornerRadius="8" BorderBrush="{DynamicResource Graviton.Background.Colour}" BorderThickness="1" Background="Transparent">
                <StackPanel>
                    <TextBlock Name="StatusTitle" Text="Status Sync" FontWeight="Bold" FontSize="20" Margin="10,10,10,15" />
                    <CheckBox IsChecked="{Binding KeepStatusSynced, Mode=TwoWay}" Margin="5">
                        <TextBlock Name="KeepStatusSyncedText" Text="Keep completion status in sync with RomM" TextWrapping="Wrap"/>
                    </CheckBox>
                    <CheckBox IsChecked="{Binding KeepFavouritesSynced, Mode=TwoWay}" Margin="5">
                        <TextBlock Name="KeepFavouritesSyncedText" Text="Keep favourites in sync with RomM" TextWrapping="Wrap"/>
                    </CheckBox>
                    <CheckBox IsChecked="{Binding KeepPrivateNotesSynced, Mode=TwoWay}" Margin="5" IsEnabled="False">
                        <TextBlock Name="KeepPrivateNotesSyncedText" Text="Keep private notes in sync with RomM" TextWrapping="Wrap"/>
                    </CheckBox>
                    <CheckBox IsChecked="{Binding KeepPublicNotesSynced, Mode=TwoWay}" Margin="5" IsEnabled="False">
                        <TextBlock Name="KeepPublicNotesSyncedText" Text="Keep public notes in sync with RomM" TextWrapping="Wrap"/>
                    </CheckBox>
                </StackPanel>
            </Border>

            <Border Margin="10" CornerRadius="8" BorderBrush="{DynamicResource Graviton.Background.Colour}" BorderThickness="1" Background="Transparent">
                <StackPanel>
                    <TextBlock Name="SaveSyncTitle" FontWeight="Bold" FontSize="20" Margin="10,10,10,15" />

                    <CheckBox IsChecked="{Binding SaveSyncEnabled, Mode=TwoWay}" Margin="5">
                        <TextBlock Name="SaveSyncEnabledText" Text="Enable Save Syncing" TextWrapping="Wrap"/>
                    </CheckBox>
                    <CheckBox IsChecked="{Binding DownloadSaveOnLaunch, Mode=TwoWay}" Margin="5" IsEnabled="{Binding SaveSyncEnabled}">
                        <TextBlock Name="DownloadSaveOnLaunchText" Text="Download saves on game launch" TextWrapping="Wrap"/>
                    </CheckBox>
                    <CheckBox IsChecked="{Binding UploadSaveOnFinished, Mode=TwoWay}" Margin="5" IsEnabled="{Binding SaveSyncEnabled}">
                        <TextBlock Name="UploadSaveOnFinishedText" Text="Upload saves on game exit" TextWrapping="Wrap"/>
                    </CheckBox>

                    <StackPanel Orientation="Horizontal" Margin="5">
                        <TextBlock Name="ConflictStyleText" Text="Conflict style" MinWidth="120" VerticalAlignment="Center"/>
                        <ComboBox MinWidth="180" ItemsSource="{Binding Source={StaticResource SaveConflictStyleValues}}" SelectedItem="{Binding SaveConflictStyle, Mode=TwoWay}" IsEnabled="{Binding SaveSyncEnabled}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumDescConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="5">
                        <CheckBox IsChecked="{Binding AutoCleanupSaves, Mode=TwoWay}" VerticalAlignment="Center" IsEnabled="{Binding SaveSyncEnabled}"/>
                        <TextBlock Name="AutoCleanupSavesText" Text="Auto Cleanup Saves" Margin="5,0,5,0" VerticalAlignment="Center"/>
                        <psdk:NumericUpDown Value="{Binding AutoCleanupSavesLimit, Mode=TwoWay}" Minimum="1" Maximum="100" Width="70" IsEnabled="{Binding AutoCleanupSaves}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Margin="10" CornerRadius="8" BorderBrush="{DynamicResource Graviton.Background.Colour}" BorderThickness="1" Background="Transparent">
                <StackPanel>
                    <TextBlock Name="SaveStateSyncTitle" FontWeight="Bold" FontSize="20" Margin="10,10,10,15" />
                    <CheckBox IsChecked="{Binding SaveStateSyncEnabled, Mode=TwoWay}" Margin="5">
                        <TextBlock Name="SaveStateSyncEnabledText" TextWrapping="Wrap"/>
                    </CheckBox>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
