<UserControl x:Class="Graviton.Settings.OptionsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:s="clr-namespace:Graviton.Settings"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="750">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        <s:ImageCacheConverter x:Key="imageCacheConverter" />
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="LightGray" />
        </Style>
        <Style TargetType="{x:Type Label}">
            <Setter Property="Foreground" Value="LightGray" />
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <Label Content="Library scanning" FontWeight="Bold" Margin="0,10,0,0" />
        <Separator Margin="0,5,0,10" />

        <CheckBox IsChecked="{Binding MergeRevisions, Mode=TwoWay}" Margin="5">
            <TextBlock Text="Merge ROM revisions" TextWrapping="Wrap"/>
        </CheckBox>
        <CheckBox IsChecked="{Binding KeepDeletedGames, Mode=TwoWay}" Margin="5">
            <TextBlock Text="Keep games deleted from RomM server" TextWrapping="Wrap"/>
        </CheckBox>
        <CheckBox IsChecked="{Binding SkipMissingFiles, Mode=TwoWay}" Margin="5">
            <TextBlock Text="Skip importing ROMs that are missing from RomM servers filesystem" TextWrapping="Wrap"/>
        </CheckBox>

        <StackPanel Orientation="Horizontal" Margin="5">
            <TextBlock Text="Exclude Genres" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5"/>
            <Grid>
                <TextBox  MinWidth="250" VerticalAlignment="Center" HorizontalAlignment="Left" x:Name="SearchTermTextBox" Margin="5" Text="{Binding ExcludeGenres, Mode=TwoWay}"/>
                <TextBlock IsHitTestVisible="False" Text="Adventure;Platform;RPG;" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="DarkGray">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=SearchTermTextBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </StackPanel>

        <Label Content="Installation" FontWeight="Bold" Margin="0,10,0,0" />
        <Separator Margin="0,5,0,10" />

        <StackPanel Orientation="Horizontal">
            <CheckBox IsChecked="{Binding Use7z, Mode=TwoWay}" Grid.Row="0" Grid.Column="0" Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Use 7z for archive extraction" TextWrapping="Wrap"/>
            </CheckBox>
            <TextBox x:Name="PathTo7zText" Grid.Row="0" Grid.Column="1" MinWidth="200" Margin="5" Text="{Binding PathTo7z, Mode=TwoWay}" />
            <Button Click="Browse7zPath_Click" Margin="0,5,5,5">
                <TextBlock Text="Browse" Margin="2"/>
            </Button>
        </StackPanel>

        <Label Content="Status Sync" FontWeight="Bold" Margin="0,10,0,0" />
        <Separator Margin="0,5,0,10" />
        <CheckBox IsChecked="{Binding KeepRomMSynced, Mode=TwoWay}" Margin="5">
            <TextBlock Text="Keep completion status and favourites in sync with RomM" TextWrapping="Wrap"/>
        </CheckBox>
    </StackPanel>

</UserControl>
