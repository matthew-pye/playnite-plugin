<UserControl x:Class="Graviton.Settings.AuthenticationTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:s="clr-namespace:Graviton.Settings"
             xmlns:playnite="clr-namespace:Playnite;assembly=Playnite.SDK"
             mc:Ignorable="d"
             d:DesignHeight="540" d:DesignWidth="960">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        <s:ImageCacheConverter x:Key="imageCacheConverter" />
        <s:InvertBoolConverter x:Key="InvertBoolConverter" />
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="LightGray" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="{x:Type Label}">
            <Setter Property="Foreground" Value="LightGray" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="{x:Type PasswordBox}">
            <Setter Property="Foreground" Value="LightGray" />
        </Style>
    </UserControl.Resources>

    <StackPanel>

        <Border Grid.Column="0" BorderThickness="1" CornerRadius="3" BorderBrush="#22696969">
            <Grid Margin="5,10,5,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="5*"/>
                </Grid.ColumnDefinitions>

                <!-- #region UserData -->
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" BorderThickness="1" CornerRadius="3" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="#ebfeefb3"/>
                                <Setter Property="Background" Value="#ebfeefb3"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="OK">
                                        <Setter Property="BorderBrush" Value="#ebd5fa97"/>
                                        <Setter Property="Background" Value="#ebd5fa97"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="Unauthorized">
                                        <Setter Property="BorderBrush" Value="#ebffbaba"/>
                                        <Setter Property="Background" Value="#ebffbaba"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="Forbidden">
                                        <Setter Property="BorderBrush" Value="#ebffbaba"/>
                                        <Setter Property="Background" Value="#ebffbaba"/>
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding AccountState.AuthenticateFailed}" Value="{x:Null}" />
                                            <Condition Binding="{Binding AccountState.UserID}" Value="-1" />
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.Setters>
                                            <Setter Property="BorderBrush" Value="#eba6a5a5"/>
                                            <Setter Property="Background" Value="#eba6a5a5"/>
                                        </MultiDataTrigger.Setters>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="12" FontFamily="{x:Static playnite:Fonts.NerdFont}" Margin="3,0,3,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#xf444;"/>
                                        <Setter Property="Foreground" Value="#ff9f6000"/>
                                        <!-- TODO flash when reconnecting (Claude recommendation?) -->
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="OK">
                                                <Setter Property="Foreground" Value="#ff4f8a10"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="Unauthorized">
                                                <Setter Property="Foreground" Value="#ffd8000c"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="Forbidden">
                                                <Setter Property="Foreground" Value="#ffd8000c"/>
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding AccountState.AuthenticateFailed}" Value="{x:Null}" />
                                                    <Condition Binding="{Binding AccountState.UserID}" Value="-1" />
                                                </MultiDataTrigger.Conditions>
                                                <MultiDataTrigger.Setters>
                                                    <Setter Property="Foreground" Value="#ff696969"/>
                                                </MultiDataTrigger.Setters>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock FontSize="12" Margin="0,0,3,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Reconnecting..."/>
                                        <Setter Property="Foreground" Value="#ff9f6000"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="OK">
                                                <Setter Property="Text" Value="Logged In"/>
                                                <Setter Property="Foreground" Value="#ff4f8a10"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="Unauthorized">
                                                <Setter Property="Text" Value="Logged Out"/>
                                                <Setter Property="Foreground" Value="#ffd8000c"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="Forbidden">
                                                <Setter Property="Text" Value="Logged Out"/>
                                                <Setter Property="Foreground" Value="#ffd8000c"/>
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding AccountState.AuthenticateFailed}" Value="{x:Null}" />
                                                    <Condition Binding="{Binding AccountState.UserID}" Value="-1" />
                                                </MultiDataTrigger.Conditions>
                                                <MultiDataTrigger.Setters>
                                                    <Setter Property="Text" Value="Not Logged In"/>
                                                    <Setter Property="Foreground" Value="#ff696969"/>
                                                </MultiDataTrigger.Setters>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,5,0">
                        <Label Name="RomMServerVersionText" Content="Server Ver." Foreground="DimGray" FontSize="12"/>
                        <Label Name="RomMServerVersion" Content="{Binding AccountState.ServerVersion, Mode=OneWay}" Foreground="DimGray" FontSize="12" Margin="0"/>
                    </StackPanel>

                    <!-- #region Profile Icon -->
                    <Grid Grid.Column="0" Grid.Row="2" Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid Name="ProfileIconGrid" Grid.Column="0">
                            <Border Name="ProfileIconBorder" BorderThickness="0" CornerRadius="8" ClipToBounds="True">
                                <Border.Background>
                                    <ImageBrush ImageSource="{Binding ProfilePath, Mode=OneWay, Converter={StaticResource imageCacheConverter}}" Stretch="UniformToFill" AlignmentX="Center" AlignmentY="Center"/>
                                </Border.Background>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, ElementName=ProfileIconGrid}" Value="True">
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsMouseOver, ElementName=ProfileEditButton}" Value="True">
                                                <Setter Property="Opacity" Value="0.5"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Grid>
                        <Button Grid.Column="0" Name="ProfileEditButton" Content="&#xf03eb;" FontSize="24" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="10" Click="Click_UpdateProfileIcon">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Opacity" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=ProfileIconGrid}" Value="True">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                    <!-- #endregion -->

                    <TextBlock Name="RomMLoggedStatus" Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="2" FontSize="18" FontWeight="Bold" VerticalAlignment="Bottom" Margin="5">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="OK">
                                        <Setter Property="Text" Value="Logged In"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="Unauthorized">
                                        <Setter Property="Text" Value="Logged Out"/>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="Forbidden">
                                        <Setter Property="Text" Value="Logged Out"/>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding AccountState.AuthenticateFailed}" Value="{x:Null}" />
                                            <Condition Binding="{Binding AccountState.UserID}" Value="-1" />
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.Setters>
                                            <Setter Property="Text" Value="Not Logged In"/>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger.Setters>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Name="RomMUser" Text="{Binding AccountState.User, Mode=OneWay}" Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="2" FontSize="22" FontWeight="Bold" Margin="10,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="OK">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Name="RomMProfileType" Text="{Binding AccountState.UserType, Mode=OneWay}" Grid.Column="0" Grid.Row="4" Grid.ColumnSpan="2" Margin="20,0,0,0" Foreground="DimGray" FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AccountState.AuthenticateFailed}" Value="OK">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </Grid>
                <!-- #endregion -->

                <Border Grid.Column="0" BorderThickness="1" CornerRadius="3" BorderBrush="#41696969" Width="1" HorizontalAlignment="Right" Margin="0,0,-1,0"/>

                <!-- #region Login -->
                <Grid Grid.Column="1">

                    
                    
                </Grid>
                <!-- #endregion -->
                
            </Grid>
        </Border>
