        <!-- #region Advance Options -->
        <TextBlock Name="AdvanceOptionsText" Grid.Row="8" Grid.ColumnSpan="2" Margin="5" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="18" FontWeight="Bold"/>
        <Separator Grid.Row="8" Grid.ColumnSpan="4" VerticalAlignment="Bottom" Margin="5"/>

        <TextBlock Name="CustomHeadersText" Text="Custom Headers" Grid.Row="9" Grid.ColumnSpan="2" Margin="5" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="10" Grid.ColumnSpan="2">
            <ItemsControl ItemsSource="{Binding CustomHeaders, Mode=TwoWay}" Grid.Row="9" Grid.ColumnSpan="2">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding Enabled}" Checked="Header_Checked" Unchecked="Header_Unchecked" />
                            <Grid>
                                <TextBox MinWidth="250" VerticalAlignment="Center" HorizontalAlignment="Left" x:Name="HeaderNameText" Margin="5" Text="{Binding Name, Mode=TwoWay}" IsEnabled="{Binding Enabled, Converter={StaticResource InvertBoolConverter}}"/>
                                <TextBlock x:Name="HeaderNamePlaceholderText" IsHitTestVisible="False" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="DarkGray">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=HeaderNameText}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <Grid>
                                <TextBox MinWidth="250" VerticalAlignment="Center" HorizontalAlignment="Left" x:Name="HeaderValueText" Margin="5" Text="{Binding Value, Mode=TwoWay}" IsEnabled="{Binding Enabled, Converter={StaticResource InvertBoolConverter}}"/>
                                <TextBlock x:Name="HeaderValuePlaceholderText" IsHitTestVisible="False" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="DarkGray">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=HeaderValueText}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <Button Click="Click_RemoveHeader" FontSize="16" Margin="5" HorizontalAlignment="Left">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#6a3a3a"/>
                                        <Setter Property="Opacity" Value="0.6"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    </ContentPresenter>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="1"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Name="DeleteHeaderText"  Text="&#xf05e8;" Margin="2,0,5,0"/>
                            </Button>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Click="Click_AddHeader" FontSize="16" Margin="5" HorizontalAlignment="Left">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Foreground" Value="Gray"/>
                        <Setter Property="Opacity" Value="0.6"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                    </ContentPresenter>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="1"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <TextBlock Name="AddHeaderText" Margin="2,0,5,0"/>
            </Button>
        </StackPanel>
        <!-- #endregion -->

    </StackPanel>

</UserControl>