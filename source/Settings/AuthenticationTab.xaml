<UserControl x:Class="Graviton.Settings.AuthenticationTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:s="clr-namespace:Graviton.Settings"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="750">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        <s:ImageCacheConverter x:Key="imageCacheConverter" />
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="LightGray" />
        </Style>
        <Style TargetType="{x:Type Label}">
            <Setter Property="Foreground" Value="LightGray" />
        </Style>
        <Style TargetType="{x:Type PasswordBox}">
            <Setter Property="Foreground" Value="LightGray" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="0,0,0,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="120"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="85"/>
            <RowDefinition Height="85"/>
            <RowDefinition Height="45"/>
            <RowDefinition Height="45"/>
            <RowDefinition Height="45"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="45"/>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="45"/>
        </Grid.RowDefinitions>

        <Grid Name="ProfileIconGrid" Grid.Row="0" Grid.RowSpan="2" Width="160" Height="160" Margin="0,5,0,5">
            <Border Name="ProfileIconBorder" BorderThickness="0" CornerRadius="8" ClipToBounds="True">
                <Border.Background>
                    <ImageBrush ImageSource="{Binding ProfilePath, Mode=OneWay, Converter={StaticResource imageCacheConverter}}" Stretch="UniformToFill" AlignmentX="Center" AlignmentY="Center"/>
                </Border.Background>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMouseOver, ElementName=ProfileIconGrid}" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsMouseOver, ElementName=ProfileEditButton}" Value="True">
                                <Setter Property="Opacity" Value="0.5"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <Button Name="ProfileEditButton" Content="&#xf03eb;" FontSize="24" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="10" Click="Click_UpdateProfileIcon">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Opacity" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMouseOver, ElementName=ProfileIconGrid}" Value="True">
                                <Setter Property="Opacity" Value="0.5"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="1"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <Label Name="RomMUser" Content="{Binding User, Mode=OneWay}" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" FontSize="22" VerticalAlignment="Bottom" Margin="5,0,0,0"/>
        <Label Name="RomMProfileType" Content="{Binding UserType, Mode=OneWay}" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Top" Margin="5,0,0,0" Foreground="DimGray" FontSize="12" />
        <Button Name="TestServer" Click="Click_Authenticate" Grid.Row="1" Grid.Column="3" Margin="0,5,0,0" HorizontalAlignment="Center" VerticalAlignment="Top">
            <TextBlock Name="AuthButtonText" Text="Authenticate" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Button>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,5,10,0">
            <Label Name="RomMServerVersionText" Content="Server Ver." Foreground="DimGray" FontSize="12" VerticalAlignment="Top" HorizontalAlignment="Center"/>
            <Label Name="RomMServerVersion" Content="{Binding ServerVersion, Mode=OneWay}" Foreground="DimGray" FontSize="12" HorizontalAlignment="Center" Margin="0"/>
        </StackPanel>

        <TextBlock Name="ServerHostText" Text="RomM Server Address" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="RomMHost" Grid.Row="2" Grid.Column="1" Margin="0,5,5,5" VerticalAlignment="Center" HorizontalAlignment="Stretch" Text="{Binding Host, Mode=TwoWay}" />

        <Button Name="QRAuth" Click="Click_LoginViaQR" Grid.Row="2" Grid.Column="2" Margin="0,5,5,5" HorizontalAlignment="Left" VerticalAlignment="Center">
            <TextBlock Name="QRAuthText" Text="Login via QR Code" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Button>

        <TextBlock Grid.Row="3" Grid.Column="0" Margin="5" VerticalAlignment="Center">
               <Hyperlink Name="ClientTokenLink" RequestNavigate="Hyperlink_ClientToken" NavigateUri="{Binding Host}">
                  <Run Name="TokenText" Text="Client Token"/>
               </Hyperlink>
        </TextBlock>
        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,5,5,5" VerticalAlignment="Center" HorizontalAlignment="Stretch" Text="{Binding ClientTokenNP, Mode=TwoWay}" />

        <CheckBox IsChecked="{Binding UseBasicAuth, Mode=TwoWay}" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Unchecked="Unchecked_UseBasicAuth" Checked="Checked_UseBasicAuth">
            <TextBlock Name="UseBasicAuthText" Text="Use Basic Auth" TextWrapping="Wrap" FontSize="12"/>
        </CheckBox>

        <TextBlock Name="UserPassWarning" Text="Warning! Using this is NOT recommended!" TextWrapping="Wrap" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" TextAlignment="Center" VerticalAlignment="Top" Margin="5,15,5,5" Visibility="{Binding UseBasicAuth, Converter={StaticResource BoolToVisConverter}}" Foreground="#ffb329" Grid.RowSpan="2"/>

        <TextBlock Name="UsernameText" Text="Username" Grid.Row="6" Grid.Column="0" Margin="40,0,5,5" VerticalAlignment="Center" HorizontalAlignment="Stretch" Visibility="{Binding UseBasicAuth, Converter={StaticResource BoolToVisConverter}}"/>
        <TextBox x:Name="RomMUsername" Grid.Row="6" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Stretch" Height="25" Text="{Binding UsernameNP, Mode=TwoWay}" Visibility="{Binding UseBasicAuth, Converter={StaticResource BoolToVisConverter}}"/>

        <TextBlock Name="PasswordText" Text="Password" Grid.Row="7" Grid.Column="0" Margin="40,5,5,0" VerticalAlignment="Center" HorizontalAlignment="Stretch" Visibility="{Binding UseBasicAuth, Converter={StaticResource BoolToVisConverter}}"/>
        <TextBox x:Name="RomMPasswordUnmasked" Grid.Row="7" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Stretch" Height="25" Text="{Binding PasswordNP, Mode=TwoWay}" Visibility="Collapsed"/>
        <PasswordBox x:Name="RomMPassword" Grid.Row="7" Grid.Column="1" PasswordChar="●" VerticalAlignment="Center" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" FontSize="14" Height="25" Visibility="{Binding UseBasicAuth, Converter={StaticResource BoolToVisConverter}}"/>
        <Button Name="ShowPassword" Content="&#xea70;" Grid.Row="7" Grid.Column="1" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Right" Height="25" Margin="0,0,5,0" Click="Click_ShowPassword" Visibility="{Binding UseBasicAuth, Converter={StaticResource BoolToVisConverter}}">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="Foreground" Value="DimGray"/>
                    <Setter Property="Opacity" Value="0.7"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>

        <Image Name="LoginQR" Margin="10" Grid.Row="3" Grid.Column="2" Grid.RowSpan="6" Grid.ColumnSpan="2" Stretch="Uniform"/>
        <TextBlock Name="LoginQRTimer" Grid.Row="9" Grid.Column="2" Grid.ColumnSpan="2" HorizontalAlignment="Center"/>
    </Grid>

</UserControl>